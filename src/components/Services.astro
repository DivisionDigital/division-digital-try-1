---
// Services.astro — Grid Animado GSAP Flip (Expansión On-Scroll)
// Estado Inicial: 20 cajas pequeñas (1x1). 
// Estado Final: Cajas expansivas cobran vida y tamaño al entrar al viewport,
// desplazando a las "pequeñas" hacia abajo. Si las pequeñas rebasan la cuadrícula de 4x5, desaparecen.

const gridData = [
  // 8 Cajas que se pueden expandir y alternar tamaños (Ahora todas son de 2x2 para ser formas muy cuadradas)
  { word: "Mega E-Commerce", phrase: "Tiendas online a medida y escalables.", cols: 2, rows: 2, expands: true, image: "/Servicios/mega-ecommerce.png" },
  { word: "Chatbots IA", phrase: "Agentes inteligentes cerrando ventas 24/7.", cols: 2, rows: 2, expands: true, image: "/Servicios/chatbots-ia.png" },
  { word: "Catálogo Plus", phrase: "Filtros y miles de SKUs automatizados.", cols: 2, rows: 2, expands: true, image: "/Servicios/catalogo-plus.png" },
  { word: "WhatsApp Bot", phrase: "Cotizaciones automáticas en el chat.", cols: 2, rows: 2, expands: true, image: "/Servicios/whatsapp-bot.png" },
  { word: "Analítica VIP", phrase: "Dashboard real-time con estadísticas.", cols: 2, rows: 2, expands: true, image: "/Servicios/analitica-vip.png" },
  { word: "Diseño UX/UI", phrase: "Interfaces modernas de alta retención.", cols: 2, rows: 2, expands: true, image: "/Servicios/diseno-ux-ui.png" },
  { word: "Escalabilidad", phrase: "Infraestructura elástica para crecer.", cols: 2, rows: 2, expands: true, image: "/Servicios/escalabilidad.png" },
  { word: "Seguridad TLS", phrase: "Cifrado militar en transacciones.", cols: 2, rows: 2, expands: true, image: "/Servicios/seguridad-tls.png" },

  // Cajas "Mortero" que sirven de relleno y fluyen dinámicamente
  { word: "Velocidad", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/velocidad.png" },
  { word: "Cloud API", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/cloud-api.png" },
  { word: "Arquitectura", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/arquitectura.png" },
  { word: "Inventarios", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/inventarios.png" },
  { word: "Tráfico B2B", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/trafico-b2b.png" },
  { word: "Ventas B2C", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/ventas-b2c.png" },
  { word: "Datos Core", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/datos-core.png" },
  { word: "Soporte Pro", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/soporte-pro.png" },
  { word: "Cifrado E2E", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/cifrado-e2e.png" },
  { word: "Global CDN", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/global-cdn.png" },
  { word: "Optimización", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/optimizacion.png" },
  { word: "Métricas", phrase: "", cols: 1, rows: 1, expands: false, image: "/Servicios/metricas.png" }
];

// Hay 20 cajas exactamente. 
// Las sorteamos al azar para que el orden de configuración de origen varíe.
const bentoItems = [...gridData].sort(() => Math.random() - 0.5);
---

<section id="servicios" class="section services-section">
  <!-- Glowing effects -->
  <div class="services-glow glow-orb glow-orb-accent" aria-hidden="true"></div>

  <div class="container-fluid" style="padding: 0 4%;">
    <div class="section-header" style="max-width: 800px; margin: 0 auto 3rem auto; text-align: center;">
      <span class="section-label reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Galería de Servicios
      </span>
      <h2 class="reveal" data-delay="0.1">Ecosistema <span class="text-gradient">Fluido</span></h2>
      <p class="reveal" data-delay="0.2">
        Las soluciones robustas desplazan a lo simple. Un sistema diseñado para priorizar lo que realmente importa en tu negocio al instante.
      </p>
    </div>

    <!-- 
      Grid Limitado: 4 Filas Exactas (4 * 150 + 3 gaps = 648px)
      Las cajas que son desbordadas de aquí caerán en el "overflow: hidden" suavemente por la animación.
    -->
    <div class="bento-wrapper overflow-lock reveal" data-delay="0.3">
      <div class="dense-bento-grid">
        {
          bentoItems.map((item) => (
            <!-- INICIALMENTE TODO ES CHICO (col-span-1 row-span-1) PARA CABER.
                 Mantenemos data-target listos para ser leídos por Flip. -->
            <div
              class="bento-cell col-span-1 row-span-1 is-compact"
              data-target-col={item.cols}
              data-target-row={item.rows}
            >
              <!-- Fondo (Imagen 100% si existe) -->
              <div class="bento-bg-image">
                {item.image ? (
                  <img src={item.image} alt={item.word} loading="lazy" />
                ) : (
                  <div class="bg-placeholder-pattern"></div>
                )}
              </div>

              <!-- Degradado oscuro -->
              <div class="bento-overlay"></div>

              <!-- Contenidos: Se revelará la 'phrase' solo si el CSS detecta que creció -->
              <div class="bento-content">
                <h3 class="bento-word">{item.word}</h3>
                <p class="bento-phrase">{item.phrase}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(ScrollTrigger, Flip);

  function initBentoAnimation() {
    const grid = document.querySelector(".dense-bento-grid");
    const wrapper = document.querySelector(".bento-wrapper");
    const cellsArray = Array.from(grid?.querySelectorAll(".bento-cell") || []);

    if (!grid || !wrapper || cellsArray.length === 0) return;

    // --- Efecto de Interacción: Click en la Imagen ---
    // Se añade un evento a cada tarjeta para que al hacer click, solo se anime la imagen interna
    cellsArray.forEach((cell) => {
      const img = cell.querySelector('img, .bg-placeholder-pattern');
      if (img) {
        // Le damos estilo de botón para que el usuario sepa que es clickeable
        (cell as HTMLElement).style.cursor = 'pointer';
        
        cell.addEventListener('click', () => {
          if (gsap.isTweening(img)) return;

          // Animación Premium: Efecto Táctil
          // Se hunde rápido como un botón físico, y se recupera con mucha inercia y elegancia
          gsap.timeline()
            .to(img, {
              scale: 0.95,
              opacity: 0.5,
              duration: 0.1,
              ease: "power2.inOut"
            })
            .to(img, {
              scale: 1,
              opacity: 1,
              duration: 0.8,
              ease: "expo.out" 
            });
        });
      }
    });

    // Detectar qué módulos son expansibles leyendo si su target es mayor a 1
    const expandableCells = cellsArray.filter((cell) => {
      const col = parseInt(cell.getAttribute("data-target-col") || "1");
      const row = parseInt(cell.getAttribute("data-target-row") || "1");
      return col > 1 || row > 1;
    });

    // GSAP MatchMedia: Accesibilidad, Responsive y Limpieza de Memoria
    let mm = gsap.matchMedia();

    mm.add("(min-width: 900px)", () => {
      // Accesibilidad: checamos nativamente el movimiento reducido para evitar errores de tipado de GSAP
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (prefersReducedMotion) return;

      let currentIndex = 0;
      let timer: ReturnType<typeof gsap.delayedCall> | null = null;
      let activeFlipTween: any = null; // Guardamos el tween para el cleanup
      
      // Bucle Mágico de GSAP Flip (Expansión única y lenta por ciclo)
      function animateGridStep() {
        const state = Flip.getState(cellsArray);

        // Regresamos TODAS al estado base (fusión en reverso)
        expandableCells.forEach((cell) => {
          cell.classList.remove("col-span-2", "row-span-2");
          cell.classList.add("col-span-1", "row-span-1", "is-compact");
        });

        const gridContainer = document.querySelector(".dense-bento-grid");

        // Mantenemos 4 celdas expandidas a la vez. 
        const numExpanded = 4;
        const currentActiveBoxes = [];
        
        for (let i = 0; i < numExpanded; i++) {
          const cellToExpand = expandableCells[(currentIndex + i) % expandableCells.length];
          const tCol = cellToExpand.getAttribute("data-target-col");
          const tRow = cellToExpand.getAttribute("data-target-row");
          cellToExpand.classList.remove("col-span-1", "row-span-1", "is-compact");
          cellToExpand.classList.add(`col-span-${tCol}`, `row-span-${tRow}`);
          currentActiveBoxes.push(cellToExpand);
        }

        // TRUCO DE GRID:
        // Movemos físicamente las cajas expandidas al principio del DOM contenedor.
        // Esto fuerza al CSS Grid a ubicarlas en la parte superior (filas 1 a la 3).
        // Evita que cajas gigantes sean arrojadas a la fila 4 y se corten a la mitad con el overflow.
        if (gridContainer) {
          currentActiveBoxes.reverse().forEach(box => gridContainer.prepend(box));
        }

        // Animación de fusión súper suave
        activeFlipTween = Flip.from(state, {
          duration: 2.2,            // Más tiempo = más elegante
          ease: "power2.inOut",     // Desaceleración en los bordes
          absolute: true,           
          onComplete: () => {
            currentIndex++;
            // Espera 3.5 segundos contemplando la caja grande antes del sigiendo cambio
            timer = gsap.delayedCall(3.5, animateGridStep);
          }
        });
      }

      ScrollTrigger.create({
        trigger: wrapper,
        start: "top 80%",
        once: true,
        onEnter: () => {
          animateGridStep();
        }
      });

      // Cleanup vital: Astro SPAs o resizes de pantalla deben limpiar memoria (GSAP Core Standard)
      return () => {
        if (timer) timer.kill();
        if (activeFlipTween) activeFlipTween.kill();
        // Restaurar estado DOM a compacto
        expandableCells.forEach((cell) => {
          cell.classList.remove("col-span-2", "row-span-2");
          cell.classList.add("col-span-1", "row-span-1", "is-compact");
        });
      };
    });

    // MÓVIL (Efecto Stacking / Tarjetas Apilables)
    mm.add("(max-width: 899px)", () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (prefersReducedMotion) return;

      // Desactivamos clases limitantes de tamaño inicial
      expandableCells.forEach((c) => {
        c.classList.remove("col-span-1", "row-span-1", "is-compact");
        // Les damos la clase grande para que el CSS aplique los estilos de tarjeta expandida
        c.classList.add("col-span-2", "row-span-2");
      });

      let triggers: ScrollTrigger[] = [];

      // Efecto Stacking: las cartas se encogen y pierden opacidad a medida que suben por debajo de la siguiente
      expandableCells.forEach((card, index) => {
        if (index === expandableCells.length - 1) return; // La última carta no se encoge porque nada la tapa

        const st = ScrollTrigger.create({
          trigger: card,
          start: "top 120px", // Mismo valor que el top de position: sticky en CSS
          endTrigger: wrapper, // Terminar efecto al final de toda la sección
          end: "bottom top", 
          pin: false, // Usamos position: sticky de CSS nativo para mejor performance
          pinSpacing: false,
          scrub: true,
          animation: gsap.to(card, {
            scale: 0.92 - (index * 0.01),
            opacity: 0.3,
            transformOrigin: "top center",
            ease: "none"
          })
        });
        triggers.push(st);
      });

      return () => {
        triggers.forEach(t => t.kill());
        expandableCells.forEach((c) => {
          c.classList.add("col-span-1", "row-span-1", "is-compact");
          c.classList.remove("col-span-2", "row-span-2");
          gsap.set(c, { clearProps: "all" });
        });
      };
    });
  }

  initBentoAnimation();
  document.addEventListener('astro:page-load', initBentoAnimation);
</script>

<style>
  .services-section {
    position: relative;
    background: var(--bg-secondary);
    padding: var(--space-xl) 0;
  }

  .services-glow {
    width: 700px; height: 700px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.1;
    pointer-events: none;
  }

  /* 
    ENVOLTORIO ESTRICTO (El pozo desbordante)
    Debe tener ALTURA FIJA para que el Flip (absolute:true) no colapse el grid
    a 0 pixeles y los elementos "desaparezcan y aparezcan de la nada".
    (4 * 240px) + (3 gaps * 16px) = 1008px
  */
  .bento-wrapper {
    position: relative;
    width: 100%;
    max-width: 1264px; /* Limita el ancho y hace que las cajas 1x1 sean de ~240x240px */
    margin: 0 auto; /* Centra la cuadrícula */
    height: 1008px; /* ALTURA FIJA ESTRICTA */
    overflow: hidden; 
    border-radius: var(--radius-xl);
  }

  .dense-bento-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 240px; /* Incrementado para forzar que las cajas 1x1 sean cuadradas */
    grid-auto-flow: dense;
    gap: 16px;
    width: 100%;
    height: 100%; /* Fuerza a heredar la altura para no colapsar nunca */
    position: relative;
  }

  /* Span Classes Reales para CSS Grid */
  .col-span-1 { grid-column: span 1; }
  .col-span-2 { grid-column: span 2; }
  .row-span-1 { grid-row: span 1; }
  .row-span-2 { grid-row: span 2; }

  /* Molde de la caja */
  .bento-cell {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    
    /* Fondo casi transparente y desenfoque para integrarse con la página */
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    
    /* Relieve sutil integrado */
    border: 1px solid rgba(255, 255, 255, 0.02);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-left: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 
      0 10px 30px rgba(0, 0, 0, 0.1), 
      inset 0px 1px 1px rgba(255, 255, 255, 0.03);

    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-lg);
  }

  /* Contenedores de color e imagen al 100% */
  .bento-bg-image {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bg-placeholder-pattern {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(45deg, rgba(247, 8, 92, 0.02), rgba(247, 8, 92, 0.02) 10px, transparent 10px, transparent 20px);
  }
  .bento-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    /* Reducimos la oscuridad del overlay para que el fondo de la página respire más */
    background: linear-gradient(to top, rgba(10, 10, 15, 0.7) 0%, rgba(10, 10, 15, 0.05) 60%, transparent 100%);
    pointer-events: none;
  }

  /* Para que un <img> opcional que añadas fluya perfectamente adentro */
  .bento-bg-image :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  /* Espacio de la tipografía */
  .bento-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bento-word {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    /* Suave transición en caso de que mute de caja chicha a caja enorme */
    transition: font-size 0.8s ease, color 0.8s ease;
  }

  .bento-phrase {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.4;
    margin: 0;
    display: none; 
    opacity: 0;
  }

  /* Lógica de Visibilidad de Textos tras el Desplazamiento Flip */
  /* Si la caja YA NO es compacta desvanecemos suavemente la frase descriptiva */
  .bento-cell:not(.is-compact).col-span-2 .bento-phrase, 
  .bento-cell:not(.is-compact).row-span-2 .bento-phrase {
    display: block;
    animation: fadeMio 0.8s ease forwards 0.5s; /* Un ligero delay para no verse mientras se mueve */
  }
  
  @keyframes fadeMio { to { opacity: 0.85; } }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    /* Optimización Móvil: Ocultamos el relleno */
    .bento-cell[data-target-col="1"] {
      display: none !important;
    }
    
    /* Configuración para Stacking Cards */
    .bento-wrapper { 
      width: 92%; 
      max-width: 500px;
      height: auto !important; /* Permitir scroll libre */
      overflow: visible !important; /* Requisito estricto para position: sticky */
      padding-bottom: 4rem; /* Aire al final */
    } 
    .dense-bento-grid { 
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .bento-cell {
      position: sticky;
      top: 120px; /* Punto donde se atascan */
      height: 380px; /* Altura generosa para ver el texto e imagen */
      width: 100%;
    }
    
    /* Forzar visibilidad del texto sin animaciones de delay molestas */
    .bento-phrase {
      display: block !important;
      opacity: 0.85 !important;
      animation: none !important;
    }
  }

  @media (max-width: 500px) {
    .bento-wrapper { width: 90%; }
    .bento-cell { 
      height: 340px; 
      top: 100px;
    }
  }
</style>
