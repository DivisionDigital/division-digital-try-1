---
// ChatWidget.astro — Floating chat widget (UI only, no backend)
---

<!-- Overlay backdrop for mobile fullscreen -->
<div class="chat-overlay" id="chatOverlay"></div>

<div class="chat-widget" id="chatWidget">
  <!-- Toggle Button -->
  <button
    class="chat-widget-toggle"
    id="chatWidgetToggle"
    aria-label="Abrir chat"
    aria-expanded="false"
  >
    <svg class="chat-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <svg class="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <!-- Chat Panel -->
  <div class="chat-widget-panel" id="chatWidgetPanel">
    <div class="widget-header">
      <div class="widget-header-info">
        <div class="widget-avatar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8V4H8"/><rect x="8" y="8" width="8" height="8" rx="1"/><path d="M4 12h4"/><path d="M16 12h4"/><path d="M12 16v4"/></svg>
        </div>
        <div>
          <span class="widget-title">División Digital</span>
          <span class="widget-status">
            <span class="widget-status-dot"></span>
            En línea — Respuesta inmediata
          </span>
        </div>
      </div>
      <!-- Close button inside header (visible on mobile fullscreen) -->
      <button class="widget-header-close" id="widgetHeaderClose" aria-label="Cerrar chat">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="widget-messages" id="widgetMessages">
      <div class="widget-msg bot">
        <p>¡Hola! 👋 Bienvenido a División Digital.</p>
      </div>
      <div class="widget-msg bot">
        <p>¿Te interesa crear tu tienda online o integrar un chat con IA? Cuéntame más sobre tu proyecto.</p>
      </div>
    </div>

    <div class="widget-quick-actions">
      <button class="quick-btn" data-msg="Quiero crear un E-Commerce">🛒 E-Commerce</button>
      <button class="quick-btn" data-msg="Me interesa el Chat con IA">🤖 Chat IA</button>
      <button class="quick-btn" data-msg="Necesito una cotización">💰 Cotización</button>
    </div>

    <div class="widget-input-area">
      <input type="text" id="widgetInput" placeholder="Escribe un mensaje..." />
      <button class="widget-send" id="widgetSend" aria-label="Enviar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  /* Overlay — only visible on mobile when chat is open */
  .chat-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: calc(var(--z-modal) - 1);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    display: none;
  }

  .chat-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .chat-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: var(--z-modal);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-md);
  }

  /* Toggle Button */
  .chat-widget-toggle {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--gradient-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-accent-lg);
    transition: all var(--transition-base);
    position: relative;
  }

  .chat-widget-toggle:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 40px rgba(247, 8, 92, 0.5);
  }

  .chat-widget-toggle .close-icon {
    display: none;
  }

  .chat-widget-toggle.active .chat-icon {
    display: none;
  }

  .chat-widget-toggle.active .close-icon {
    display: block;
  }

  /* Pulse ring */
  .chat-widget-toggle::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    opacity: 0;
    animation: chatPulse 3s ease-in-out infinite;
  }

  .chat-widget-toggle.active::before {
    display: none;
  }

  @keyframes chatPulse {
    0%, 100% { opacity: 0; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.15); }
  }

  /* Chat Panel */
  .chat-widget-panel {
    width: 380px;
    max-height: 520px;
    background: var(--bg-secondary);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg), 0 0 60px rgba(247, 8, 92, 0.1);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    transition: all var(--transition-base);
  }

  .chat-widget-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .widget-header {
    padding: var(--space-md) var(--space-lg);
    background: rgba(247, 8, 92, 0.08);
    border-bottom: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .widget-header-info {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  /* Close button inside header — hidden on desktop, shown on mobile */
  .widget-header-close {
    display: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--glass-border-subtle);
    color: var(--text-secondary);
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .widget-header-close:hover {
    background: rgba(247, 8, 92, 0.15);
    color: var(--accent);
    border-color: var(--accent);
  }

  .widget-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent-subtle);
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .widget-title {
    display: block;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  .widget-status {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.6875rem;
    color: #28c840;
  }

  .widget-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #28c840;
    animation: pulse 2s infinite;
  }

  /* Messages */
  .widget-messages {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    min-height: 200px;
    max-height: 280px;
  }

  .widget-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .widget-msg.bot {
    align-self: flex-start;
    background: var(--bg-tertiary);
    border: 1px solid var(--glass-border-subtle);
    border-bottom-left-radius: 4px;
  }

  .widget-msg.bot p {
    color: var(--text-secondary);
    margin: 0;
    font-size: 0.8125rem;
  }

  .widget-msg.user {
    align-self: flex-end;
    background: var(--accent);
    border-bottom-right-radius: 4px;
  }

  .widget-msg.user p {
    color: white;
    margin: 0;
    font-size: 0.8125rem;
  }

  /* Quick Actions */
  .widget-quick-actions {
    display: flex;
    gap: var(--space-xs);
    padding: 0 var(--space-lg) var(--space-sm);
    flex-wrap: wrap;
  }

  .quick-btn {
    padding: 6px 12px;
    font-size: 0.6875rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--glass-border-subtle);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .quick-btn:hover {
    border-color: var(--accent);
    color: var(--accent-light);
    background: var(--accent-subtle);
  }

  /* Input */
  .widget-input-area {
    display: flex;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--glass-border-subtle);
  }

  .widget-input-area input {
    flex: 1;
    padding: 10px 14px;
    background: var(--bg-tertiary);
    border: 1px solid var(--glass-border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 0.8125rem;
    min-width: 0;
  }

  .widget-input-area input::placeholder {
    color: var(--text-muted);
  }

  .widget-input-area input:focus {
    border-color: var(--accent);
  }

  .widget-send {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }

  .widget-send:hover {
    background: var(--accent-light);
  }

  /* ========================================
     MOBILE: Fullscreen chat panel
     ======================================== */
  @media (max-width: 768px) {
    .chat-overlay {
      display: block;
    }

    .chat-widget {
      bottom: 16px;
      right: 16px;
    }

    /* Smaller toggle on mobile */
    .chat-widget-toggle {
      width: 48px;
      height: 48px;
    }

    .chat-widget-toggle svg {
      width: 18px;
      height: 18px;
    }

    .chat-widget-toggle::before {
      inset: -3px;
    }

    /* Fullscreen chat panel on mobile */
    .chat-widget-panel {
      position: fixed;
      inset: 0;
      width: 100%;
      max-width: 100%;
      max-height: 100%;
      height: 100%;
      border-radius: 0;
      border: none;
      transform: translateY(100%);
      opacity: 1;
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .chat-widget-panel.open {
      transform: translateY(0);
    }

    /* Show close button in header on mobile */
    .widget-header-close {
      display: flex;
    }

    .widget-header {
      padding: var(--space-md) var(--space-lg);
      /* Safe area for notch/status bar */
      padding-top: max(var(--space-md), env(safe-area-inset-top, 12px));
    }

    .widget-messages {
      min-height: 0;
      max-height: none;
      flex: 1;
      padding: var(--space-md);
    }

    .widget-input-area {
      /* Safe area for home indicator */
      padding-bottom: max(var(--space-md), env(safe-area-inset-bottom, 12px));
    }

    .quick-btn {
      padding: 8px 14px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 380px) {
    .chat-widget {
      bottom: 12px;
      right: 12px;
    }

    .chat-widget-toggle {
      width: 44px;
      height: 44px;
    }

    .chat-widget-toggle svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  function initChatWidget() {
    const toggle = document.getElementById('chatWidgetToggle');
    const panel = document.getElementById('chatWidgetPanel');
    const overlay = document.getElementById('chatOverlay');
    const headerClose = document.getElementById('widgetHeaderClose');
    const input = document.getElementById('widgetInput') as HTMLInputElement;
    const sendBtn = document.getElementById('widgetSend');
    const messages = document.getElementById('widgetMessages');
    const quickBtns = document.querySelectorAll('.quick-btn');

    const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

    function openChat() {
      toggle?.classList.add('active');
      toggle?.setAttribute('aria-expanded', 'true');
      panel?.classList.add('open');

      if (isMobile()) {
        overlay?.classList.add('visible');
        document.body.style.overflow = 'hidden';
      }

      if (input) {
        setTimeout(() => input.focus(), 350);
      }
    }

    function closeChat() {
      toggle?.classList.remove('active');
      toggle?.setAttribute('aria-expanded', 'false');
      panel?.classList.remove('open');
      overlay?.classList.remove('visible');
      document.body.style.overflow = '';
    }

    // Toggle panel via FAB
    toggle?.addEventListener('click', () => {
      const isOpen = panel?.classList.contains('open');
      if (isOpen) {
        closeChat();
      } else {
        openChat();
      }
    });

    // Close via header X button (mobile)
    headerClose?.addEventListener('click', closeChat);

    // Close via overlay tap (mobile)
    overlay?.addEventListener('click', closeChat);

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel?.classList.contains('open')) {
        closeChat();
      }
    });

    // Send message function
    function sendMessage(text: string) {
      if (!text.trim() || !messages) return;

      // User message
      const userMsg = document.createElement('div');
      userMsg.className = 'widget-msg user';
      userMsg.innerHTML = `<p>${text}</p>`;
      messages.appendChild(userMsg);

      gsap.from(userMsg, { opacity: 0, y: 10, duration: 0.3, ease: 'back.out(1.7)' });

      // Bot response after delay
      setTimeout(() => {
        const botMsg = document.createElement('div');
        botMsg.className = 'widget-msg bot';
        botMsg.innerHTML = `<p>¡Gracias por tu interés! Un agente se pondrá en contacto contigo pronto. También puedes escribirnos directamente a nuestro <a href="#contacto" style="color: var(--accent); text-decoration: underline;">formulario de contacto</a>. 🚀</p>`;
        messages.appendChild(botMsg);

        gsap.from(botMsg, { opacity: 0, y: 10, duration: 0.3, ease: 'back.out(1.7)' });
        messages.scrollTop = messages.scrollHeight;
      }, 1000);

      if (input) input.value = '';
      messages.scrollTop = messages.scrollHeight;

      // Hide quick actions
      const quickActions = document.querySelector('.widget-quick-actions') as HTMLElement;
      if (quickActions) quickActions.style.display = 'none';
    }

    // Send button
    sendBtn?.addEventListener('click', () => {
      if (input) sendMessage(input.value);
    });

    // Enter key
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendMessage(input.value);
    });

    // Quick action buttons
    quickBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const msg = (btn as HTMLElement).dataset.msg;
        if (msg) sendMessage(msg);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initChatWidget);
  document.addEventListener('astro:page-load', initChatWidget);
</script>
