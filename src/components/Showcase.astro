              ></polyline></svg
            >
          </div>
          <div>
            <h4>Dashboard Administrativo</h4>
            <p>
              Panel completo para gestionar productos, pedidos, clientes y
              reportes en tiempo real.
            </p>
          </div>
        </div>
        <div class="feature-item reveal" data-delay="0.4">
          <div class="feature-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
