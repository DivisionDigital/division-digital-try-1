          </div>
          <div class="mockup-content">
            <div class="mockup-scroll-area">
              <div class="mockup-header-bar">
                <div class="mockup-logo-placeholder"></div>
                <div class="mockup-nav-items">
                  <span class="click-target-5"></span><span></span><span
                    class="click-target-4"></span><span></span>
                </div>
              </div>
              <div class="mockup-hero-area">
                <div class="mockup-hero-text">
                  <div class="mockup-line mockup-line-lg"></div>
                  <div class="mockup-line mockup-line-md"></div>
                  <div class="mockup-line mockup-line-sm click-target-3"></div>
                </div>
              </div>
              <div class="mockup-products">
                <div class="mockup-product-card click-target-1"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card click-target-2"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card click-target-4"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card"></div>
              </div>

              <!-- Contenido simulado adicional para permitir el scroll -->
              <div class="mockup-hero-area" style="padding-top: 24px;">
                <div class="mockup-hero-text">
                  <div class="mockup-line mockup-line-md"></div>
                  <div class="mockup-line mockup-line-lg"></div>
                </div>
              </div>
              <div class="mockup-products">
                <div class="mockup-product-card click-target-3"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card click-target-5"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card click-target-1"></div>
                <div class="mockup-product-card"></div>
                <div class="mockup-product-card"></div>
              </div>
              <div
                class="mockup-hero-area"
                style="padding-top: 24px; padding-bottom: 24px;"
              >
                <div class="mockup-hero-text">
                  <div class="mockup-line mockup-line-sm click-target-2"></div>
                  <div class="mockup-line mockup-line-md"></div>
                  <div class="mockup-line mockup-line-lg"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature highlights -->
      <div class="showcase-features">
        <div class="feature-item reveal" data-delay="0.3">
          <div class="feature-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
