</section>

<style>
  .showcase-section {
    background: var(--bg-primary);
    overflow: hidden;
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-3xl);
  }

  .showcase-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    margin-bottom: var(--space-4xl);
  }

  /* Browser Mockup */
  .mockup-container {
    perspective: 1000px;
  }

  .mockup-browser {
    background: #1a1a2e;
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border-subtle);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transform: rotateY(-3deg) rotateX(2deg);
    transition: transform var(--transition-slow);
  }

  .mockup-browser:hover {
    transform: rotateY(0) rotateX(0);
  }

  .mockup-browser:hover .mockup-scroll-area {
    animation-play-state: paused;
  }

  .mockup-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--glass-border-subtle);
  }

  .mockup-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red {
    background: #ff5f57;
  }
  .dot-yellow {
    background: #febc2e;
  }
  .dot-green {
    background: #28c840;
  }

  .mockup-url {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-muted);
    flex: 1;
    max-width: 280px;
  }

  .mockup-content {
    padding: var(--space-md);
    height: 280px;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
  }

  .mockup-scroll-area {
    display: flex;
    flex-direction: column;
    animation: browseScroll 10s cubic-bezier(0.4, 0, 0.2, 1) infinite alternate;
  }

  @keyframes browseScroll {
    0%,
    5% {
      transform: translateY(0);
    }
    20%,
    30% {
      transform: translateY(-20%);
    }
    45%,
    55% {
      transform: translateY(-40%);
    }
    75%,
    100% {
      transform: translateY(-60%);
    }
  }

  .click-target-1 {
    animation: autoClick 3.2s infinite;
  }
  .click-target-2 {
    animation: autoClick 4.5s infinite 1.2s;
  }
  .click-target-3 {
    animation: autoClick 5s infinite 0.5s;
  }
  .click-target-4 {
    animation: autoClick 2.8s infinite 2s;
  }
  .click-target-5 {
    animation: autoClick 6s infinite 3.5s;
  }

  @keyframes autoClick {
    0%,
    92% {
      transform: scale(1);
      filter: brightness(1);
    }
    96% {
      transform: scale(0.85);
      filter: brightness(1.6);
    }
    100% {
      transform: scale(1);
      filter: brightness(1);
    }
  }

  .mockup-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mockup-logo-placeholder {
    width: 80px;
    height: 12px;
    background: var(--accent);
    border-radius: 4px;
    opacity: 0.7;
  }

  .mockup-nav-items {
    display: flex;
    gap: 8px;
  }

  .mockup-nav-items span {
    width: 32px;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .mockup-hero-area {
    padding: var(--space-lg) 0;
  }

  .mockup-line {
    height: 10px;
    border-radius: 5px;
    margin-bottom: 8px;
  }

  .mockup-line-lg {
    width: 85%;
    background: rgba(255, 255, 255, 0.15);
  }

  .mockup-line-md {
    width: 60%;
    background: rgba(255, 255, 255, 0.08);
  }

  .mockup-line-sm {
    width: 40%;
    background: linear-gradient(90deg, var(--accent), #a855f7);
    opacity: 0.8;
    height: 28px;
    border-radius: var(--radius-sm);
    margin-top: var(--space-md);
  }

  .mockup-products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .mockup-product-card {
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Agregando colores simulados a los productos para darle vida */
  .mockup-product-card:nth-child(4n + 1) {
    background: linear-gradient(
      135deg,
      rgba(255, 95, 87, 0.15),
      rgba(255, 95, 87, 0.02)
    );
    border-color: rgba(255, 95, 87, 0.1);
  }
  .mockup-product-card:nth-child(4n + 2) {
    background: linear-gradient(
      135deg,
      rgba(254, 188, 46, 0.15),
      rgba(254, 188, 46, 0.02)
    );
    border-color: rgba(254, 188, 46, 0.1);
  }
  .mockup-product-card:nth-child(4n + 3) {
    background: linear-gradient(
      135deg,
      rgba(40, 200, 64, 0.15),
      rgba(40, 200, 64, 0.02)
    );
    border-color: rgba(40, 200, 64, 0.1);
  }
  .mockup-product-card:nth-child(4n + 4) {
    background: linear-gradient(
      135deg,
      rgba(10, 132, 255, 0.15),
      rgba(10, 132, 255, 0.02)
    );
    border-color: rgba(10, 132, 255, 0.1);
  }

  /* Features */
  .showcase-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .feature-item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border-subtle);
    background: var(--glass-bg);
    transition: all var(--transition-base);
  }

  .feature-item:hover {
    border-color: var(--glass-border);
    background: var(--glass-bg-light);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--accent-subtle);
    color: var(--accent);
    flex-shrink: 0;
  }

  .feature-item h4 {
    color: var(--text-primary);
    margin-bottom: 4px;
    font-family: "Space Grotesk", sans-serif;
  }

  .feature-item p {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Brands Carousel */
  .brands-section {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--glass-border-subtle);
    margin-top: var(--space-xl);
  }

  .brands-title {
    text-align: center;
    font-family: "Space Grotesk", sans-serif;
    color: var(--text-muted);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-2xl);
  }

  .brands-carousel {
    width: 100%;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .brands-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    padding-right: 4rem; /* Match gap exactly for seamless loop calculation */
    animation: scrollBrands 35s linear infinite;
  }

  .brands-track:hover {
    animation-play-state: paused;
  }

  .brands-track a {
    display: inline-block;
    transition: transform var(--transition-base);
  }

  .brands-track a:hover {
    transform: scale(1.1);
  }

  .brand-logo {
    height: 64px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6) brightness(2); /* Optimizando legibilidad en fondo oscuro */
    transition: filter var(--transition-base);
  }

  .brands-track a:hover .brand-logo {
    filter: grayscale(0%) opacity(1) brightness(1);
  }

  @keyframes scrollBrands {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 960px) {
    .showcase-layout {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .mockup-browser {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .brands-track {
      gap: 2.5rem;
      padding-right: 2.5rem;
    }
    .brand-logo {
      height: 48px;
    }
  }

  @media (max-width: 480px) {
    .brands-title {
      font-size: 0.875rem;
    }
  }
</style>

