---
// Showcase.astro — Portfolio showcase with animated stats and mockup
---

<section id="portafolio" class="section showcase-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        Portafolio
      </span>
      <h2 class="reveal" data-delay="0.1">Lo que <span class="text-gradient">Creamos</span></h2>
      <p class="reveal" data-delay="0.2">
        E-Commerce completos con miles de productos, chat integrado y experiencia de usuario premium.
      </p>
    </div>

    <div class="showcase-layout">
      <!-- Browser Mockup -->
      <div class="mockup-container reveal-scale" data-delay="0.2">
        <div class="mockup-browser">
          <div class="mockup-toolbar">
            <div class="mockup-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="mockup-url">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              electrificadoracapital.com
            </div>
          </div>
          <div class="mockup-content">
            <div class="mockup-header-bar">
              <div class="mockup-logo-placeholder"></div>
              <div class="mockup-nav-items">
                <span></span><span></span><span></span><span></span>
              </div>
            </div>
            <div class="mockup-hero-area">
              <div class="mockup-hero-text">
                <div class="mockup-line mockup-line-lg"></div>
                <div class="mockup-line mockup-line-md"></div>
                <div class="mockup-line mockup-line-sm"></div>
              </div>
            </div>
            <div class="mockup-products">
              <div class="mockup-product-card"></div>
              <div class="mockup-product-card"></div>
              <div class="mockup-product-card"></div>
              <div class="mockup-product-card"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature highlights -->
      <div class="showcase-features">
        <div class="feature-item reveal" data-delay="0.3">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div>
            <h4>Dashboard Administrativo</h4>
            <p>Panel completo para gestionar productos, pedidos, clientes y reportes en tiempo real.</p>
          </div>
        </div>
        <div class="feature-item reveal" data-delay="0.4">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h4>Seguridad Enterprise</h4>
            <p>SSL, protección contra fraude, GDPR compliance y pagos seguros integrados.</p>
          </div>
        </div>
        <div class="feature-item reveal" data-delay="0.5">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <div>
            <h4>Rendimiento Optimizado</h4>
            <p>Carga ultra rápida, SEO optimizado y responsive en todos los dispositivos.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Counter -->
    <div class="showcase-stats">
      <div class="stat-block reveal" data-delay="0.3">
        <span class="stat-counter" data-target="50">0</span>
        <span class="stat-plus">+</span>
        <span class="stat-text">Proyectos Entregados</span>
      </div>
      <div class="stat-block reveal" data-delay="0.4">
        <span class="stat-counter" data-target="14000">0</span>
        <span class="stat-plus">+</span>
        <span class="stat-text">Productos Gestionados</span>
      </div>
      <div class="stat-block reveal" data-delay="0.5">
        <span class="stat-counter" data-target="99">0</span>
        <span class="stat-plus">%</span>
        <span class="stat-text">Clientes Satisfechos</span>
      </div>
      <div class="stat-block reveal" data-delay="0.6">
        <span class="stat-counter" data-target="5">0</span>
        <span class="stat-plus">+</span>
        <span class="stat-text">Años de Experiencia</span>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase-section {
    background: var(--bg-primary);
    overflow: hidden;
  }

  .showcase-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    margin-bottom: var(--space-4xl);
  }

  /* Browser Mockup */
  .mockup-container {
    perspective: 1000px;
  }

  .mockup-browser {
    background: #1a1a2e;
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border-subtle);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transform: rotateY(-3deg) rotateX(2deg);
    transition: transform var(--transition-slow);
  }

  .mockup-browser:hover {
    transform: rotateY(0) rotateX(0);
  }

  .mockup-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--glass-border-subtle);
  }

  .mockup-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .mockup-url {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-muted);
    flex: 1;
    max-width: 280px;
  }

  .mockup-content {
    padding: var(--space-md);
    min-height: 280px;
  }

  .mockup-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .mockup-logo-placeholder {
    width: 80px;
    height: 12px;
    background: var(--accent);
    border-radius: 4px;
    opacity: 0.7;
  }

  .mockup-nav-items {
    display: flex;
    gap: 8px;
  }

  .mockup-nav-items span {
    width: 32px;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .mockup-hero-area {
    padding: var(--space-lg) 0;
  }

  .mockup-line {
    height: 10px;
    border-radius: 5px;
    margin-bottom: 8px;
  }

  .mockup-line-lg {
    width: 85%;
    background: rgba(255, 255, 255, 0.15);
  }

  .mockup-line-md {
    width: 60%;
    background: rgba(255, 255, 255, 0.08);
  }

  .mockup-line-sm {
    width: 40%;
    background: var(--accent);
    opacity: 0.4;
    height: 28px;
    border-radius: var(--radius-sm);
    margin-top: var(--space-md);
  }

  .mockup-products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .mockup-product-card {
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Features */
  .showcase-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .feature-item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border-subtle);
    background: var(--glass-bg);
    transition: all var(--transition-base);
  }

  .feature-item:hover {
    border-color: var(--glass-border);
    background: var(--glass-bg-light);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--accent-subtle);
    color: var(--accent);
    flex-shrink: 0;
  }

  .feature-item h4 {
    color: var(--text-primary);
    margin-bottom: 4px;
    font-family: 'Space Grotesk', sans-serif;
  }

  .feature-item p {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Stats */
  .showcase-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    padding: var(--space-2xl);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border-subtle);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(16px);
  }

  .stat-block {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .stat-counter {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-plus {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-text {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .showcase-layout {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .mockup-browser {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .showcase-stats {
      grid-template-columns: repeat(2, 1fr);
      padding: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .showcase-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  function initCounters() {
    const counters = document.querySelectorAll('.stat-counter');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target || '0', 10);
            const obj = { val: 0 };

            gsap.to(obj, {
              val: target,
              duration: 2,
              ease: 'power2.out',
              onUpdate: () => {
                el.textContent = Math.round(obj.val).toLocaleString();
              },
            });

            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    counters.forEach((c) => observer.observe(c));
  }

  document.addEventListener('DOMContentLoaded', initCounters);
  document.addEventListener('astro:page-load', initCounters);
</script>
