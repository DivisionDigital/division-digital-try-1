---
// Process.astro — Work process timeline
const steps = [
  {
    number: '01',
    title: 'Consultoría',
    description: 'Analizamos tu negocio, objetivos y competencia para diseñar la estrategia digital ideal.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  },
  {
    number: '02',
    title: 'Diseño UI/UX',
    description: 'Creamos prototipos visuales y flujos de usuario optimizados para maximizar conversiones.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
  },
  {
    number: '03',
    title: 'Desarrollo',
    description: 'Programamos tu e-commerce con tecnología moderna, integraciones y chat multiagente.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    number: '04',
    title: 'Lanzamiento',
    description: 'Desplegamos, optimizamos SEO y brindamos soporte continuo post-lanzamiento.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>`,
  },
];
---

<section id="proceso" class="section process-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        Cómo Trabajamos
      </span>
      <h2 class="reveal" data-delay="0.1">Nuestro <span class="text-gradient">Proceso</span></h2>
      <p class="reveal" data-delay="0.2">
        Un flujo de trabajo probado que garantiza resultados excepcionales en cada proyecto.
      </p>
    </div>

    <div class="process-timeline">
      {steps.map((step, i) => (
        <div class="process-step reveal" data-delay={String(0.15 + i * 0.15)}>
          <div class="step-connector" aria-hidden="true">
            <div class="step-line"></div>
          </div>
          <div class="step-number-wrap">
            <span class="step-number">{step.number}</span>
            <div class="step-icon" set:html={step.icon} />
          </div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    background: var(--bg-secondary);
  }

  .process-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    position: relative;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding-top: var(--space-xl);
  }

  .step-connector {
    position: absolute;
    top: 52px;
    left: 55%;
    right: -45%;
    height: 2px;
    z-index: 0;
  }

  .process-step:last-child .step-connector {
    display: none;
  }

  .step-line {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--glass-border-subtle));
    border-radius: var(--radius-full);
    opacity: 0.4;
  }

  .step-number-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg-secondary);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
    transition: all var(--transition-base);
  }

  .process-step:hover .step-number {
    background: var(--accent);
    color: white;
    box-shadow: var(--shadow-accent-lg);
  }

  .step-icon {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .step-content h3 {
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .step-content p {
    font-size: 0.875rem;
    line-height: 1.6;
    max-width: 240px;
    margin: 0 auto;
  }

  @media (max-width: 960px) {
    .process-timeline {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }

    .step-connector {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .process-timeline {
      grid-template-columns: 1fr;
    }
  }
</style>
