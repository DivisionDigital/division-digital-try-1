  },
];
---

<section id="proceso" class="section process-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        Cómo Trabajamos
      </span>
      <h2 class="reveal" data-delay="0.1">Nuestro <span class="text-gradient">Proceso</span></h2>
      <p class="reveal" data-delay="0.2">
        Un flujo de trabajo probado que garantiza resultados excepcionales en cada proyecto.
      </p>
    </div>

    <div class="process-timeline">
      {steps.map((step, i) => (
        <div class="process-step reveal" data-delay={String(0.15 + i * 0.15)}>
          <div class="step-connector" aria-hidden="true">
            <div class="step-line-track"></div>
            <div class="step-line"></div>
          </div>
          <div class="step-number-wrap">
            <span class="step-number">{step.number}</span>
            <div class="step-icon" set:html={step.icon} />
          </div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    background: var(--bg-secondary);
  }

  .process-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    position: relative;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding-top: var(--space-xl);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .process-step.is-active,
  .process-step:hover {
    transform: scale(1.05);
    z-index: 2;
  }

  .step-connector {
    position: absolute;
    top: 52px;
    left: 55%;
    right: -45%;
    height: 4px;
    z-index: 0;
  }

  .process-step:last-child .step-connector {
    display: none;
  }

  .step-line-track {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--glass-border-subtle);
    border-radius: var(--radius-full);
    opacity: 0.5;
  }

  .step-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-glow));
    border-radius: var(--radius-full);
    transform-origin: left center;
    transform: scaleX(0);
    box-shadow: 0 0 10px var(--accent-glow);
    z-index: 1;
  }

  .step-number-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg-secondary);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .process-step.is-active .step-number,
  .process-step:hover .step-number {
    background: var(--accent);
    color: white;
    box-shadow: var(--shadow-accent-lg);
    border-color: var(--accent);
  }

  .step-icon {
    color: var(--text-muted);
    opacity: 0.7;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .process-step.is-active .step-icon,
  .process-step:hover .step-icon {
    color: var(--accent);
    opacity: 1;
    transform: scale(1.1);
  }

  .step-content h3 {
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center bottom;
  }

  .process-step.is-active .step-content h3,
  .process-step:hover .step-content h3 {
    transform: scale(1.15);
    color: white;
  }

  .step-content p {
    font-size: 0.875rem;
    line-height: 1.6;
    max-width: 240px;
    margin: 0 auto;
    color: var(--text-muted);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center top;
  }

  .process-step.is-active .step-content p,
  .process-step:hover .step-content p {
    transform: scale(1.05);
    color: var(--text-primary);
  }

  @media (max-width: 960px) {
    .process-timeline {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }

    .step-connector {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .process-timeline {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initProcessAnimation = () => {
    const timelineEl = document.querySelector('.process-timeline');
    if (!timelineEl) return;

    const steps = gsap.utils.toArray('.process-step') as HTMLElement[];
    const lines = gsap.utils.toArray('.step-line') as HTMLElement[];

    // Create the timeline
    const tl = gsap.timeline({ 
      repeat: -1,
      paused: true
    });

    steps.forEach((step, i) => {
      // Activar el paso actual
      tl.add(() => step.classList.add('is-active'))
        .to({}, { duration: 0.5 }); // Tiempo que dura encendido antes de mover la línea

      if (i < steps.length - 1) {
        // Animar la línea hacia el siguiente paso si existe
        tl.to(lines[i], { scaleX: 1, duration: 0.8, ease: "power2.inOut" })
          .add(() => step.classList.remove('is-active')); // Apagar mientras enciende el siguiente
      } else {
        // Si es el último paso, dejarlo un momento encendido
        tl.to({}, { duration: 0.5 });
      }
    });

    // Momento clímax: Encender TODOS los pasos
    tl.add(() => {
      steps.forEach(s => s.classList.add('is-active'));
    })
    .to({}, { duration: 1.5 }); // Mantener todo iluminado un momento

    // Resetear para el loop
    tl.add(() => {
      steps.forEach(s => s.classList.remove('is-active'));
    })
    .to(lines, { scaleX: 0, duration: 0.8, ease: "power3.inOut" })
    .to({}, { duration: 0.5 }); // Pequeña pausa antes de reiniciar el loop

    // Iniciar cuando sea visible
    ScrollTrigger.create({
      trigger: '.process-section',
      start: 'top 70%',
      onEnter: () => tl.play(),
      onLeave: () => tl.pause(),
      onEnterBack: () => tl.play(),
      onLeaveBack: () => tl.pause(),
    });
  };

  initProcessAnimation();
  document.addEventListener('astro:page-load', initProcessAnimation);
</script>
